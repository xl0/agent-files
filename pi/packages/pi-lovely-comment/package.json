{
	"name": "@xl0/pi-lovely-comment",
	"version": "0.1.0",
	"description": "Pi extension that opens the last assistant message in your editor and syncs edits back into the prompt.",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.13",
	"keywords": [
		"pi-package",
		"pi-extension"
	],
	"files": [
		"extensions",
		"README.md"
	],
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"check": "bun run typecheck && bun run biome:check",
		"release": "bun publish --access public",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"biome:check": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@earendil-works/pi-coding-agent": "^0.79.10",
		"@earendil-works/pi-tui": "^0.79.10",
		"@typescript/native-preview": "^7.0.0-dev.20260502.1",
		"bun-types": "^1.3.13",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"pi": {
		"extensions": [
			"./extensions"
		]
	}
}
